# --- Core ---
NODE_ENV=development
PORT=3000
# Emit one access-log line per HTTP request (method, path, status, timing).
# HTTP_LOGGING=true
# Public base URL of this instance (used in agent enrollment scripts)
PUBLIC_BASE_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://amber:amber@localhost:5432/amber

# --- Security ---
# 32-byte master key (base64) for envelope encryption of secrets. Generate with:
#   openssl rand -base64 32
MASTER_ENCRYPTION_KEY=
# Secret for signing session JWTs. Generate with: openssl rand -base64 48
JWT_SECRET=
# Session lifetime
JWT_EXPIRES_IN=7d
# Secure cookie flag. Default: on only when PUBLIC_BASE_URL is https://.
# Must be off (http:// base URL) for login to work over plain HTTP.
# COOKIE_SECURE=false

# --- Passkeys / WebAuthn ---
# Relying Party ID — the registrable domain, no scheme or port. Defaults to the
# hostname of PUBLIC_BASE_URL. Passkeys are bound to this value.
# WEBAUTHN_RP_ID=backup.example.com
# Comma-separated list of exact browser origins allowed for passkey ceremonies.
# Defaults to the origin of PUBLIC_BASE_URL. In dev, add the Vite origin, e.g.:
# WEBAUTHN_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Restic ---
# Path to the restic binary bundled in the image (or system restic in dev)
RESTIC_BINARY=restic
# Cache/temp dir for restic operations and restore downloads
RESTIC_CACHE_DIR=./.cache/restic
RESTORE_TMP_DIR=./tmp/restore

# --- Agents ---
# The agent offline timeout is configured by admins in the UI (Admin section),
# not via env vars.
# Directory holding the compiled agent binaries (amber-agent-linux-<arch>)
# served to hosts. Bundled at /app/agent-bin in the Docker image; for local
# `npm run dev` point this at the agent's build output, e.g. ./agent/bin
# AGENT_BINARY_DIR=agent-bin

# --- Audit log ---
# Days to retain audit log entries; entries older than this are purged daily.
# Set to 0 (or a negative value) to keep entries forever.
AUDIT_RETENTION_DAYS=90

# --- Bootstrap admin (created on first start if no users exist) ---
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme

# --- SSO ---
# SSO (generic OIDC + Microsoft Entra ID) is configured by admins in the UI
# (Admin section), not via env vars.
