# --- Core ---
NODE_ENV=development
PORT=3000
# Public base URL of this instance (used in agent enrollment scripts)
PUBLIC_BASE_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://amber:amber@localhost:5432/amber

# --- Security ---
# 32-byte master key (base64) for envelope encryption of secrets. Generate with:
#   openssl rand -base64 32
MASTER_ENCRYPTION_KEY=
# Secret for signing session JWTs. Generate with: openssl rand -base64 48
JWT_SECRET=
# Session lifetime
JWT_EXPIRES_IN=7d
# Secure cookie flag. Default: on only when PUBLIC_BASE_URL is https://.
# Must be off (http:// base URL) for login to work over plain HTTP.
# COOKIE_SECURE=false

# --- Restic ---
# Path to the restic binary bundled in the image (or system restic in dev)
RESTIC_BINARY=restic
# Cache/temp dir for restic operations and restore downloads
RESTIC_CACHE_DIR=./.cache/restic
RESTORE_TMP_DIR=./tmp/restore

# --- Agents ---
# After how many missed poll intervals an agent is marked offline (seconds)
AGENT_OFFLINE_TIMEOUT_SECONDS=120
# Directory holding the compiled agent binaries (amber-agent-linux-<arch>)
# served to hosts. Bundled at /app/agent-bin in the Docker image; for local
# `npm run dev` point this at the agent's build output, e.g. ./agent/bin
# AGENT_BINARY_DIR=agent-bin

# --- Bootstrap admin (created on first start if no users exist) ---
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme

# --- SSO (optional) ---
# Generic OIDC
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Microsoft Entra ID
ENTRA_ENABLED=false
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
