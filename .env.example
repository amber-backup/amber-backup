# Environment for docker-compose.yml. Copy to .env and fill in the secrets:
#   cp .env.example .env

# Database password (used by both the db and app services)
POSTGRES_PASSWORD=change-this-db-password

# REQUIRED secrets
#   openssl rand -base64 32   -> MASTER_ENCRYPTION_KEY (must decode to 32 bytes)
#   openssl rand -base64 48   -> JWT_SECRET
MASTER_ENCRYPTION_KEY=
JWT_SECRET=

# Public URL of this instance (used in agent enrollment commands).
# Its scheme also decides cookie security: https:// -> Secure cookies,
# http:// -> non-Secure (required for login to work over plain HTTP).
PUBLIC_BASE_URL=http://localhost:3000

# Optional: force the Secure cookie flag on/off (default derived from the
# PUBLIC_BASE_URL scheme). Only set this if you terminate TLS but present an
# http:// base URL, or vice versa.
# COOKIE_SECURE=false

# Host port to expose the app on
APP_PORT=3000

# Bootstrap admin (created on first start when the users table is empty)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
